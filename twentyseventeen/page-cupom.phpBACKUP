<script>
// Função para mostrar detalhes do curso
function mostrarDetalhes(elemento) {
    const cursoLine = elemento.closest('.curso-line');
    const cursoData = cursoLine.getAttribute('data-curso');
    const jsonContent = document.getElementById('json-content');
    
    try {
        const curso = JSON.parse(cursoData);
        const jsonFormatado = JSON.stringify(curso, null, 2);
        jsonContent.textContent = jsonFormatado;
        
        // Adiciona highlight visual no curso selecionado
        document.querySelectorAll('.curso-line').forEach(line => {
            line.style.backgroundColor = '';
        });
        cursoLine.style.backgroundColor = '#e3f2fd';
        
    } catch (error) {
        jsonContent.textContent = 'Erro ao carregar dados do curso: ' + error.message;
    }
}

// Função para copiar mnemônico
function copiarMneumonico(elemento) {
    const texto = elemento.textContent.trim();
    
    // Método moderno (funciona na maioria dos navegadores)
    if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(texto).then(function() {
            mostrarFeedback(elemento, 'Copiado!', '#28a745');
        }).catch(function() {
            // Fallback se der erro
            copiarFallback(texto, elemento);
        });
    } else {
        // Fallback para navegadores mais antigos
        copiarFallback(texto, elemento);
    }
}

// Método fallback para copiar
function copiarFallback(texto, elemento) {
    const textArea = document.createElement('textarea');
    textArea.value = texto;
    textArea.style.position = 'fixed';
    textArea.style.left = '-999999px';
    textArea.style.top = '-999999px';
    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();
    
    try {
        document.execCommand('copy');
        mostrarFeedback(elemento, 'Copiado!', '#28a745');
    } catch (err) {
        mostrarFeedback(elemento, 'Erro!', '#dc3545');
    }
    
    document.body.removeChild(textArea);
}

// Mostra feedback visual
function mostrarFeedback(elemento, texto, cor) {
    const original = elemento.textContent;
    const corOriginal = elemento.style.backgroundColor;
    
    elemento.style.backgroundColor = cor;
    elemento.style.color = 'white';
    elemento.textContent = texto;
    
    setTimeout(function() {
        elemento.style.backgroundColor = corOriginal;
        elemento.style.color = '';
        elemento.textContent = original;
    }, 1000);
}

document.addEventListener('DOMContentLoaded', function() {
    // Conta o total de cursos
    const totalCursos = document.querySelectorAll('.curso-line').length;
    const totalElement = document.getElementById('total-cursos');
    if (totalElement) {
        totalElement.textContent = totalCursos;
    }

    // Filtro por modalidade
    const filtroModalidade = document.getElementById('filtroModalidade');
    const cursoLines = document.querySelectorAll('.curso-line');

    filtroModalidade.addEventListener('change', function() {
        const filtroSelecionado = this.value;
        let cursosVisiveis = 0;

        cursoLines.forEach(function(linha) {
            const modalidade = linha.getAttribute('data-modalidade');
            
            if (filtroSelecionado === '' || modalidade === filtroSelecionado) {
                linha.style.display = '';
                cursosVisiveis++;
            } else {
                linha.style.display = 'none';
            }
        });

        // Atualiza contador
        if (totalElement) {
            totalElement.textContent = cursosVisiveis;
        }
    });

    // Adiciona hover effect nos mnemônicos e nomes de curso
    const mneumonicos = document.querySelectorAll('.mneumonico-copy');
    mneumonicos.forEach(function(elemento) {
        elemento.addEventListener('mouseenter', function() {
            this.style.backgroundColor = '#e0e0e0';
        });
        
        elemento.addEventListener('mouseleave', function() {
            this.style.backgroundColor = '#f0f0f0';
        });
    });

    // Hover effect para nomes de curso
    const nomeCursos = document.querySelectorAll('.curso-nome');
    nomeCursos.forEach(function(elemento) {
        elemento.addEventListener('mouseenter', function() {
            this.style.color = '#007bff';
        });
        
        elemento.addEventListener('mouseleave', function() {
            this.style.color = '#333';
        });
    });

    // GERADOR DE URL COM CUPOM
    const cursosData = [];
    
    // Coleta dados dos cursos para os selects
    cursoLines.forEach(function(linha) {
        const cursoData = linha.getAttribute('data-curso');
        if (cursoData) {
            try {
                const curso = JSON.parse(cursoData);
                cursosData.push(curso);
            } catch (error) {
                console.error('Erro ao processar curso:', error);
            }
        }
    });

    // Popula o select de cursos
    const selectCurso = document.getElementById('selectCurso');
    const selectUnidade = document.getElementById('selectUnidade');
    const selectTurno = document.getElementById('selectTurno');
    
    // Cria lista de cursos únicos com todas as informações
    const cursosCompletos = [];
    
    cursosData.forEach(function(curso) {
        const nomeCurso = curso.curso || curso.nome || '';
        const mneumonico = curso.mnemonico || curso.mneumonico || '';
        const modalidadeOriginal = curso.modalidade || 'Presencial';
        
        // Melhor detecção da modalidade
        let modalidade = 'Presencial';
        const modalidadeLower = modalidadeOriginal.toLowerCase();
        
        if (modalidadeLower.includes('ead') || modalidadeLower.includes('digital') || modalidadeLower.includes('distancia') || modalidadeLower.includes('online')) {
            modalidade = 'Digital (EaD)';
        }
        
        // console.log('Curso:', nomeCurso, 'Modalidade Original:', modalidadeOriginal, 'Modalidade Processada:', modalidade);
        
        if (nomeCurso && mneumonico) {
            // Cria identificador único
            const identificador = `${nomeCurso}_${mneumonico}_${modalidade}`;
            
            if (!cursosCompletos.find(c => c.identificador === identificador)) {
                cursosCompletos.push({
                    identificador: identificador,
                    nome: nomeCurso,
                    mneumonico: mneumonico,
                    modalidade: modalidade,
                    dadosOriginais: curso
                });
            }
        }
    });

    // Ordena por nome do curso
    cursosCompletos.sort((a, b) => a.nome.localeCompare(b.nome));

    // Popula o select com formato: "Nome - Mnemônico - Modalidade"
    cursosCompletos.forEach(function(cursoInfo) {
        const option = document.createElement('option');
        option.value = JSON.stringify(cursoInfo);
        option.textContent = `${cursoInfo.nome} - ${cursoInfo.mneumonico} - ${cursoInfo.modalidade}`;
        selectCurso.appendChild(option);
    });

    // 1. Quando seleciona um curso (que já contém nome, mnemônico e modalidade)
    selectCurso.addEventListener('change', function() {
        const cursoSelecionado = this.value;
        console.log('Curso selecionado:', cursoSelecionado);
        
        // Limpa e desabilita os outros selects
        selectUnidade.innerHTML = '<option value="">-- Carregando unidades... --</option>';
        selectTurno.innerHTML = '<option value="">-- Selecione unidade primeiro --</option>';
        
        selectUnidade.disabled = true;
        selectTurno.disabled = true;
        
        if (cursoSelecionado) {
            try {
                const cursoInfo = JSON.parse(cursoSelecionado);
                console.log('Curso info parsed:', cursoInfo);
                console.log('Mnemônico extraído:', cursoInfo.mneumonico);
                
                // Busca dados detalhados via API para este mnemônico específico
                const apiUrl = '<?php echo get_template_directory_uri(); ?>/getAPI_cupom.php';
                const url = `${apiUrl}?mneumonico=${encodeURIComponent(cursoInfo.mneumonico)}&tipo=graduacao`;
                console.log('URL da API:', url);
                
                fetch(url)
                .then(response => {
                    console.log('Response status:', response.status);
                    console.log('Response ok:', response.ok);
                    return response.json();
                })
                .then(data => {
                    console.log('Dados recebidos da API:', data);
                    
                    if (data.success && data.data) {
                        const cursoDetalhado = data.data;
                        console.log('Curso detalhado:', cursoDetalhado);
                        
                        // ARMAZENA O CURSO COMPLETO EM VARIÁVEL GLOBAL PARA USAR DEPOIS
                        window.cursoAtualCompleto = cursoDetalhado;
                        console.log('Curso completo armazenado:', cursoDetalhado);
                        console.log('Array de investimentos completo:', cursoDetalhado.investimentos);
                        
                        selectUnidade.innerHTML = '<option value="">-- Selecione uma unidade --</option>';
                        selectUnidade.disabled = false;
                        
                        const unidades = [];
                        
                        // Processa as unidades dentro de "investimentos"
                        if (cursoDetalhado.investimentos && Array.isArray(cursoDetalhado.investimentos)) {
                            console.log('Investimentos encontrados:', cursoDetalhado.investimentos);
                            console.log('Total de investimentos:', cursoDetalhado.investimentos.length);
                            
                            // Coleta nomes únicos de unidades
                            const unidadesUnicas = [];
                            
                            cursoDetalhado.investimentos.forEach(function(investimento, index) {
                                console.log(`Investimento ${index}:`, investimento);
                                
                                const nomeUnidade = investimento.unidade;
                                console.log(`  - Unidade: "${nomeUnidade}"`);
                                console.log(`  - Horário: "${investimento.horario}"`);
                                
                                // Adiciona unidade única (sem repetir)
                                if (nomeUnidade && !unidadesUnicas.includes(nomeUnidade)) {
                                    unidadesUnicas.push(nomeUnidade);
                                    console.log(`✅ Nova unidade adicionada: "${nomeUnidade}"`);
                                }
                            });
                            
                            console.log('Unidades únicas encontradas:', unidadesUnicas);
                            
                            // Cria objetos de unidade para o select
                            unidadesUnicas.forEach(function(nomeUnidade) {
                                unidades.push({
                                    nome: nomeUnidade,
                                    cursoInfo: cursoInfo
                                });
                            });
                            
                            console.log(`✅ ${unidades.length} unidades processadas para o select`);
                        } else {
                            console.log('Estrutura investimentos não encontrada, tentando estruturas alternativas');
                            console.log('Chaves disponíveis:', Object.keys(cursoDetalhado));
                            
                            // Tenta buscar unidades diretamente
                            if (cursoDetalhado.unidades && Array.isArray(cursoDetalhado.unidades)) {
                                console.log('Unidades encontradas:', cursoDetalhado.unidades);
                                cursoDetalhado.unidades.forEach(function(unidade) {
                                    const nomeUnidade = unidade.nome || unidade.unidade || '';
                                    if (nomeUnidade && !unidades.find(u => u.nome === nomeUnidade)) {
                                        unidades.push({
                                            nome: nomeUnidade,
                                            dados: unidade,
                                            horarios: unidade.horarios || unidade.turnos || [],
                                            id: unidade.id || '',
                                            cursoInfo: cursoInfo
                                        });
                                    }
                                });
                            }
                        }
                        
                        // Se não encontrou unidades na estrutura padrão, tenta outras estruturas possíveis
                        if (unidades.length === 0) {
                            // Tenta buscar em outras possíveis estruturas da API
                            if (cursoDetalhado.campus || cursoDetalhado.unidade) {
                                const dadosUnidade = cursoDetalhado.campus || cursoDetalhado.unidade;
                                console.log('Usando dados alternativos:', dadosUnidade);
                                unidades.push({
                                    nome: dadosUnidade.nome || dadosUnidade.unidade || 'Unidade Principal',
                                    dados: dadosUnidade,
                                    turnos: dadosUnidade.turnos || cursoDetalhado.turnos || [],
                                    cursoInfo: cursoInfo
                                });
                            }
                        }
                        
                        console.log('Unidades processadas:', unidades);
                        
                        unidades.sort((a, b) => a.nome.localeCompare(b.nome));
                        
                        unidades.forEach(function(unidadeInfo) {
                            const option = document.createElement('option');
                            option.value = JSON.stringify(unidadeInfo);
                            option.textContent = unidadeInfo.nome;
                            selectUnidade.appendChild(option);
                        });
                        
                        if (unidades.length === 0) {
                            selectUnidade.innerHTML = '<option value="">-- Nenhuma unidade encontrada --</option>';
                            console.warn('Nenhuma unidade encontrada. Estrutura de dados completa:', cursoDetalhado);
                        }
                        
                    } else {
                        selectUnidade.innerHTML = '<option value="">-- Erro ao carregar unidades --</option>';
                        console.error('Erro na resposta da API:', data);
                    }
                })
                .catch(error => {
                    selectUnidade.innerHTML = '<option value="">-- Erro ao carregar unidades --</option>';
                    console.error('Erro ao buscar dados do curso:', error);
                });
                
            } catch (error) {
                console.error('Erro ao processar curso selecionado:', error);
                selectUnidade.innerHTML = '<option value="">-- Erro ao processar seleção --</option>';
            }
        } else {
            selectUnidade.innerHTML = '<option value="">-- Selecione um curso primeiro --</option>';
        }
    });

    // 2. Quando seleciona uma unidade
    selectUnidade.addEventListener('change', function() {
        const unidadeSelecionada = this.value;
        
        selectTurno.innerHTML = '<option value="">-- Selecione um turno --</option>';
        selectTurno.disabled = !unidadeSelecionada;
        
        // Limpa o campo ID
        document.getElementById('inputId').value = '';
        
        if (unidadeSelecionada) {
            try {
                const unidadeInfo = JSON.parse(unidadeSelecionada);
                const nomeUnidadeSelecionada = unidadeInfo.nome;
                console.log('Unidade selecionada:', nomeUnidadeSelecionada);
                
                const turnos = [];
                
                // Usa o array completo armazenado para filtrar por unidade
                if (window.cursoAtualCompleto && window.cursoAtualCompleto.investimentos) {
                    const todosInvestimentos = window.cursoAtualCompleto.investimentos;
                    console.log(`Filtrando ${todosInvestimentos.length} investimentos pela unidade "${nomeUnidadeSelecionada}"`);
                    
                    // Filtra investimentos que têm a mesma unidade
                    const investimentosDaUnidade = todosInvestimentos.filter(function(investimento) {
                        return investimento.unidade === nomeUnidadeSelecionada;
                    });
                    
                    console.log(`Encontrados ${investimentosDaUnidade.length} investimentos para a unidade "${nomeUnidadeSelecionada}":`, investimentosDaUnidade);
                    
                    // Coleta todos os horários únicos desses investimentos
                    const horariosUnicos = [];
                    
                    investimentosDaUnidade.forEach(function(investimento, index) {
                        const horario = investimento.horario;
                        console.log(`Investimento ${index + 1} - Horário: "${horario}"`);
                        
                        // Adiciona apenas se não existe ainda
                        if (horario && !horariosUnicos.includes(horario)) {
                            horariosUnicos.push(horario);
                            console.log(`✅ Horário "${horario}" adicionado à lista`);
                        } else if (horario) {
                            console.log(`⚠️ Horário "${horario}" já existe, ignorando duplicata`);
                        }
                    });
                    
                    console.log(`Total de horários únicos para "${nomeUnidadeSelecionada}":`, horariosUnicos);
                    
                    // Cria objetos de turno para o select
                    horariosUnicos.forEach(function(horario) {
                        turnos.push({
                            nome: horario,
                            id: horario,
                            dados: horario,
                            unidade: unidadeInfo
                        });
                    });
                    
                } else {
                    console.error('Array de investimentos não encontrado na variável global');
                }
                
                console.log('Turnos processados:', turnos);
                console.log(`Total de turnos únicos encontrados: ${turnos.length}`);
                
                turnos.sort((a, b) => a.nome.localeCompare(b.nome));
                
                turnos.forEach(function(turnoInfo) {
                    const option = document.createElement('option');
                    option.value = JSON.stringify(turnoInfo);
                    option.textContent = turnoInfo.nome;
                    selectTurno.appendChild(option);
                });
                
                if (turnos.length === 0) {
                    selectTurno.innerHTML = '<option value="">-- Nenhum horário encontrado --</option>';
                    console.warn('Nenhum horário encontrado para unidade:', unidadeInfo);
                }
                
            } catch (error) {
                console.error('Erro ao processar unidade:', error);
                selectTurno.innerHTML = '<option value="">-- Erro ao processar unidade --</option>';
            }
        }
    });

    // 3. Quando seleciona um turno - busca o ID da combinação unidade + horário
    selectTurno.addEventListener('change', function() {
        const turnoSelecionado = this.value;
        const inputId = document.getElementById('inputId');
        
        if (turnoSelecionado) {
            try {
                const turnoInfo = JSON.parse(turnoSelecionado);
                const nomeUnidade = turnoInfo.unidade.nome;
                const nomeHorario = turnoInfo.nome;
                
                console.log(`Buscando ID para combinação: Unidade="${nomeUnidade}", Horário="${nomeHorario}"`);
                
                // Busca no array completo o investimento que tem essa combinação exata
                if (window.cursoAtualCompleto && window.cursoAtualCompleto.investimentos) {
                    const investimentoCorrespondente = window.cursoAtualCompleto.investimentos.find(function(investimento) {
                        return investimento.unidade === nomeUnidade && investimento.horario === nomeHorario;
                    });
                    
                    if (investimentoCorrespondente) {
                        const idCombinacao = investimentoCorrespondente.id;
                        inputId.value = idCombinacao;
                        console.log(`✅ ID encontrado: ${idCombinacao}`, investimentoCorrespondente);
                        console.log(`Dados completos do investimento:`, {
                            id: investimentoCorrespondente.id,
                            unidade: investimentoCorrespondente.unidade,
                            horario: investimentoCorrespondente.horario,
                            cidade: investimentoCorrespondente.cidade,
                            valor: investimentoCorrespondente.valor,
                            parcelas: investimentoCorrespondente.parcelas
                        });
                    } else {
                        inputId.value = 'ID_NAO_ENCONTRADO';
                        console.error(`❌ Nenhum investimento encontrado para Unidade="${nomeUnidade}" + Horário="${nomeHorario}"`);
                        console.log('Investimentos disponíveis:', window.cursoAtualCompleto.investimentos);
                    }
                } else {
                    inputId.value = 'ARRAY_NAO_DISPONIVEL';
                    console.error('Array de investimentos não está disponível');
                }
                
            } catch (error) {
                console.error('Erro ao processar turno:', error);
                inputId.value = 'ERRO_PROCESSAMENTO';
            }
        } else {
            inputId.value = '';
        }
    });

    // 4. Botão gerar URL - chama API e mostra URL retornada
    document.getElementById('btnGerarURL').addEventListener('click', function() {
        const cursoSelecionado = selectCurso.value;
        const unidadeSelecionada = selectUnidade.value;
        const turnoSelecionado = selectTurno.value;
        const cupom = document.getElementById('inputCupom').value.trim();
        const idCombinacao = document.getElementById('inputId').value.trim();
        
        if (!cursoSelecionado) {
            alert('Por favor, selecione um curso.');
            return;
        }
        
        if (!unidadeSelecionada) {
            alert('Por favor, selecione uma unidade.');
            return;
        }
        
        if (!turnoSelecionado) {
            alert('Por favor, selecione um turno.');
            return;
        }
        
        if (!cupom) {
            alert('Por favor, digite um código de cupom.');
            return;
        }
        
        if (!idCombinacao) {
            alert('ID da combinação não foi encontrado. Tente selecionar os campos novamente.');
            return;
        }

        try {
            const cursoInfo = JSON.parse(cursoSelecionado);
            const unidadeInfo = JSON.parse(unidadeSelecionada);
            const turnoInfo = JSON.parse(turnoSelecionado);
            
            // Extrai apenas o nome do curso (sem mneumonico nem modalidade)
            const descricao_curso = cursoInfo.nome;
            
            console.log('Enviando dados para API:', {
                descricao_curso: descricao_curso,
                oferta: idCombinacao,
                cupom: cupom
            });
            
            // Chama a API sendAPI_cupom.php
            fetch('/wp-content/themes/twentyseventeen/sendAPI_cupom.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    descricao_curso: descricao_curso,  // Nome do curso apenas
                    oferta: idCombinacao,              // ID da combinação
                    cupom: cupom                       // Código do cupom
                })
            })
            .then(response => {
                console.log('Status da resposta:', response.status);
                return response.json();
            })
            .then(data => {
                console.log('Resposta da API:', data);
                
                const urlGerada = document.getElementById('urlGerada');
                const urlTexto = document.getElementById('urlTexto');
                
                if (data.success && data.data && data.data.redirect_url) {
                    // Usa a URL retornada pela API
                    const urlDaAPI = data.data.redirect_url;
                    urlTexto.textContent = urlDaAPI;
                    urlGerada.style.display = 'block';
                    
                    console.log('URL da API exibida:', urlDaAPI);
                    
                    // Auto scroll para a URL gerada
                    urlGerada.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    
                } else {
                    console.error('Resposta da API não contém redirect_url:', data);
                    alert('Erro: A API não retornou uma URL válida. Verifique os dados e tente novamente.');
                }
            })
            .catch(error => {
                console.error('Erro na chamada da API:', error);
                alert('Erro ao gerar URL. Verifique sua conexão e tente novamente.');
            });
            
        } catch (error) {
            console.error('Erro ao processar dados:', error);
            alert('Erro ao processar dados. Tente novamente.');
        }
    });
});

// Função auxiliar para verificar se string contém substring (case insensitive)
function stripos(haystack, needle) {
    return haystack.toLowerCase().indexOf(needle.toLowerCase());
}

// Função para copiar URL gerada
function copiarURL(elemento) {
    const texto = elemento.textContent.trim();
    
    if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(texto).then(function() {
            mostrarFeedbackURL(elemento, 'URL Copiada!', '#28a745');
        }).catch(function() {
            copiarFallbackURL(texto, elemento);
        });
    } else {
        copiarFallbackURL(texto, elemento);
    }
}

function copiarFallbackURL(texto, elemento) {
    const textArea = document.createElement('textarea');
    textArea.value = texto;
    textArea.style.position = 'fixed';
    textArea.style.left = '-999999px';
    textArea.style.top = '-999999px';
    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();
    
    try {
        document.execCommand('copy');
        mostrarFeedbackURL(elemento, 'URL Copiada!', '#28a745');
    } catch (err) {
        mostrarFeedbackURL(elemento, 'Erro ao copiar!', '#dc3545');
    }
    
    document.body.removeChild(textArea);
}

function mostrarFeedbackURL(elemento, texto, cor) {
    const original = elemento.textContent;
    const corOriginalFundo = elemento.style.backgroundColor;
    const corOriginalTexto = elemento.style.color;
    
    elemento.style.backgroundColor = cor;
    elemento.style.color = 'white';
    elemento.textContent = texto;
    
    setTimeout(function() {
        elemento.style.backgroundColor = corOriginalFundo;
        elemento.style.color = corOriginalTexto;
        elemento.textContent = original;
    }, 2000);
}
</script>

</body>
</html>