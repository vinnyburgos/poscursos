<?php
add_action('wp_head', function() {
    echo '<meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex, notranslate">' . "\n";
    echo '<meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet, noimageindex">' . "\n";
    echo '<meta name="bingbot" content="noindex, nofollow, noarchive, nosnippet, noimageindex">' . "\n";
    echo '<meta name="slurp" content="noindex, nofollow, noarchive, nosnippet, noimageindex">' . "\n";
}, 1);

// Remove da sitemap do Yoast SEO
add_filter('wpseo_sitemap_exclude_post_type', function($excluded, $post_type) {
    if (is_page() && get_page_template_slug() === 'page-cupom.php') {
        return true;
    }
    return $excluded;
}, 10, 2);

// Remove de feeds RSS
add_action('pre_get_posts', function($query) {
    if ($query->is_feed() && $query->is_main_query()) {
        $query->set('meta_query', array(
            array(
                'key' => '_wp_page_template',
                'value' => 'page-cupom.php',
                'compare' => '!='
            )
        ));
    }
});

// Impede tracking do Google Analytics (se estiver usando gtag)
add_action('wp_head', function() {
    if (is_page_template('page-cupom.php')) {
        echo '<script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag("config", "GA_MEASUREMENT_ID", {
                "custom_map": {"page_title": "Private Page"},
                "send_page_view": false
            });
        </script>' . "\n";
    }
}, 5);

// Adiciona header HTTP para não indexar
add_action('send_headers', function() {
    if (is_page_template('page-cupom.php')) {
        header('X-Robots-Tag: noindex, nofollow, noarchive, nosnippet');
    }
});

// Remove de resultados de busca interna do WordPress
add_action('pre_get_posts', function($query) {
    if (!is_admin() && $query->is_search() && $query->is_main_query()) {
        $meta_query = $query->get('meta_query') ?: [];
        $meta_query[] = array(
            'key' => '_wp_page_template',
            'value' => 'page-cupom.php',
            'compare' => '!='
        );
        $query->set('meta_query', $meta_query);
    }
});
?>



